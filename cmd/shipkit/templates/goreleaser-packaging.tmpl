archives:
  - name_template: "{{ "{{" }} .ProjectName {{ "}}" }}_{{ "{{" }} .Version {{ "}}" }}_{{ "{{" }} .Os {{ "}}" }}_{{ "{{" }} .Arch {{ "}}" }}"
    files:
      - LICENSE*
      - README*
      - CHANGELOG*

nfpms:
  - id: packages
    package_name: {{.ProjectName}}
    homepage: https://github.com/{{.RepoOwner}}/{{.RepoName}}
    maintainer: {{.RepoOwner}}
    description: {{.Description}}
    license: {{.License}}
    formats:
      - deb
      - rpm
      - apk

homebrew_casks:
  - repository:
      owner: {{.RepoOwner}}
      name: homebrew-tap
      token: "{{ "{{" }} .Env.HOMEBREW_TAP_GITHUB_TOKEN {{ "}}" }}"
    homepage: https://github.com/{{.RepoOwner}}/{{.RepoName}}
    description: {{.Description}}
    license: {{.License}}
